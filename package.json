{
  "name": "gameclubtelegrambot",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Game Club Telegram Bot project skeleton",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "lint": "bash -O globstar -c 'node --import tsx src/scripts/check-repo-health.ts src/**/*.ts'",
    "build": "tsc -p tsconfig.json && node dist/scripts/write-build-version.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "bash -O globstar -O extglob -c 'node --import tsx --test src/**/!(*.integration).test.ts'",
    "test:integration": "bash -O globstar -c 'node --import tsx --test src/**/*.integration.test.ts'",
    "start": "node dist/main.js",
    "tray:debian": "node dist/scripts/debian-tray.js",
    "backup:console": "node dist/scripts/backup-console.js",
    "backup:cli": "./scripts/backup-cli.sh",
    "telegram:ux": "node --import tsx src/scripts/telegram-menu-ux-report.ts",
    "telegram:ux:tui": "node --import tsx src/scripts/telegram-menu-ux-console.ts",
    "bootstrap:wizard": "node --import tsx src/scripts/bootstrap-wizard.ts",
    "config:check": "node --import tsx src/scripts/check-runtime-config.ts",
    "config:edit": "node --import tsx src/scripts/runtime-config-editor.ts",
    "config:init": "node --import tsx src/scripts/runtime-config-editor.ts --init",
    "db:generate": "node --import tsx src/scripts/generate-checked-migration.ts",
    "db:generate:checked": "node --import tsx src/scripts/generate-checked-migration.ts",
    "db:check": "node --import tsx src/scripts/check-generated-migrations.ts",
    "db:check:state": "node --import tsx src/scripts/check-drizzle-state.ts",
    "db:migrate": "node --import tsx src/scripts/migrate.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate:local": "GAMECLUB_CONFIG_PATH=config/runtime.local.json node --import tsx src/scripts/migrate.ts",
    "config:check:local": "GAMECLUB_CONFIG_PATH=config/runtime.local.json node --import tsx src/scripts/check-runtime-config.ts",
    "start:local": "GAMECLUB_CONFIG_PATH=config/runtime.local.json node --import tsx src/main.ts",
    "init:local": "./scripts/init-local.sh",
    "catalog:wikipedia:boardgame": "./scripts/wikipedia-boardgame-catalog-import.sh"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.38.3",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
