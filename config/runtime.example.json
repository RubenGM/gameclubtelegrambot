{
  "schemaVersion": 1,
  "bot": {
    "publicName": "Game Club Bot",
    "clubName": "Game Club"
  },
  "telegram": {
    "token": "replace-with-real-telegram-token",
    "localBotApi": {
      "enabled": false,
      "baseUrl": "http://127.0.0.1:8081",
      "dataDir": "/var/lib/gameclubtelegrambot/telegram-bot-api"
    }
  },
  "bgg": {
    "apiKey": "replace-with-real-bgg-api-key"
  },
  "notion": {
    "enabled": false
  },
  "database": {
    "host": "127.0.0.1",
    "port": 55432,
    "name": "gameclub",
    "user": "gameclub_user",
    "password": "replace-with-generated-password",
    "ssl": false
  },
  "adminElevation": {
    "passwordHash": "replace-with-generated-admin-password-hash"
  },
  "bootstrap": {
    "firstAdmin": {
      "telegramUserId": 123456789,
      "username": "club_admin",
      "displayName": "Club Administrator"
    }
  },
  "notifications": {
    "defaults": {
      "groupAnnouncementsEnabled": true,
      "eventRemindersEnabled": true,
      "eventReminderLeadHours": 24
    }
  },
  "featureFlags": {
    "bootstrapWizard": true
  }
}
