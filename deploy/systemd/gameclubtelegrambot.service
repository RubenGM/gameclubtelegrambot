[Unit]
Description=Game Club Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=gameclubbot
Group=gameclubbot
WorkingDirectory=/opt/gameclubtelegrambot
EnvironmentFile=-/etc/default/gameclubtelegrambot
ExecStartPre=/usr/bin/test -f /etc/gameclubtelegrambot/runtime.json
ExecStartPre=/usr/bin/test -f /opt/gameclubtelegrambot/dist/main.js
ExecStart=/usr/bin/node /opt/gameclubtelegrambot/dist/main.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
