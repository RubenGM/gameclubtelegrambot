{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "language",
    "intent",
    "confidence",
    "reply",
    "needsClarification",
    "clarification",
    "requiresConfirmation",
    "confirmation",
    "action",
    "safety"
  ],
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "language": { "type": "string", "enum": ["ca", "es", "en"] },
    "intent": {
      "type": "string",
      "enum": [
        "help.capabilities",
        "schedule.today",
        "schedule.upcoming",
        "schedule.search",
        "schedule.create",
        "schedule.join",
        "schedule.leave",
        "catalog.search",
        "catalog.detail",
        "catalog.create",
        "catalog.edit",
        "catalog.loan.create",
        "catalog.loan.list",
        "storage.search",
        "storage.category.list",
        "storage.upload.start",
        "storage.entry.detail",
        "storage.entry.edit",
        "notice.list",
        "notice.create",
        "notice.archive",
        "group_purchase.list",
        "group_purchase.detail",
        "group_purchase.join",
        "group_purchase.create",
        "lfg.list",
        "lfg.create",
        "news.status",
        "clarify",
        "unsupported"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reply": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "sendNow"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "sendNow": { "type": "boolean" }
      }
    },
    "needsClarification": { "type": "boolean" },
    "clarification": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["question", "expectedFields", "knownParams"],
          "properties": {
            "question": { "type": "string", "minLength": 1 },
            "expectedFields": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "knownParams": { "$ref": "#/$defs/params" }
          }
        }
      ]
    },
    "requiresConfirmation": { "type": "boolean" },
    "confirmation": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text", "params"],
          "properties": {
            "text": { "type": "string", "minLength": 1 },
            "params": { "$ref": "#/$defs/params" }
          }
        }
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name", "params"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "answer_directly",
            "ask_clarification",
            "request_confirmation",
            "call_internal_handler",
            "dispatch_command",
            "unsupported"
          ]
        },
        "name": { "type": "string", "minLength": 1 },
        "params": { "$ref": "#/$defs/params" }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiresApprovedMember",
        "requiresAdmin",
        "risk",
        "publicSideEffect",
        "destructive",
        "requiresPrivateChat"
      ],
      "properties": {
        "requiresApprovedMember": { "type": "boolean" },
        "requiresAdmin": { "type": "boolean" },
        "risk": { "type": "string", "enum": ["read_only", "write", "admin", "unknown"] },
        "publicSideEffect": { "type": "boolean" },
        "destructive": { "type": "boolean" },
        "requiresPrivateChat": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query",
        "dateRange",
        "tag",
        "fileExtensions",
        "id",
        "noticeId",
        "entryId",
        "categoryId",
        "itemId",
        "eventId",
        "purchaseId",
        "title",
        "text",
        "message",
        "body",
        "content",
        "description",
        "expiresAt",
        "startsAt",
        "groupTitle"
      ],
      "properties": {
        "query": { "type": ["string", "null"] },
        "dateRange": { "type": ["string", "null"], "enum": ["today", "this_week", "upcoming", null] },
        "tag": { "type": ["string", "null"] },
        "fileExtensions": { "type": "array", "items": { "type": "string" } },
        "id": { "type": ["integer", "null"] },
        "noticeId": { "type": ["integer", "null"] },
        "entryId": { "type": ["integer", "null"] },
        "categoryId": { "type": ["integer", "null"] },
        "itemId": { "type": ["integer", "null"] },
        "eventId": { "type": ["integer", "null"] },
        "purchaseId": { "type": ["integer", "null"] },
        "title": { "type": ["string", "null"] },
        "text": { "type": ["string", "null"] },
        "message": { "type": ["string", "null"] },
        "body": { "type": ["string", "null"] },
        "content": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "expiresAt": { "type": ["string", "null"] },
        "startsAt": { "type": ["string", "null"] },
        "groupTitle": { "type": ["string", "null"] }
      }
    }
  }
}
